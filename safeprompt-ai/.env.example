# Used only by `docker compose build` to substitute ${VITE_...} values
# into the frontend build args in docker-compose.yml — NOT the same
# thing as backend/.env or frontend/.env, which configure the apps
# themselves. Docker Compose automatically reads a .env file in the same
# directory as docker-compose.yml for this kind of substitution.
#
# Copy this to .env (repo root, next to docker-compose.yml) and fill in
# the same Supabase project values you used in backend/.env and
# frontend/.env.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
