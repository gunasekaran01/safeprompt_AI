# Production environment template for the backend.
#
# Copy to `.env` on your production host (or translate into your
# platform's secret/env manager — Docker Compose `env_file`,
# Railway/Render/Fly secrets, Kubernetes Secrets, etc.) rather than
# committing real values anywhere. See backend/.env.example for the full
# set of settings with development-oriented defaults and explanations;
# this file only calls out what should differ in production.

ENVIRONMENT=production
DEBUG=False

# List every real frontend origin that will call this API — no
# localhost/127.0.0.1 entries in production. Parsed as a JSON array by
# pydantic-settings.
CORS_ORIGINS=["https://your-production-domain.com"]

# --- Supabase ---------------------------------------------------------
SUPABASE_URL=https://slyaszpcympyofatkqui.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InNseWFzenBjeW1weW9mYXRrcXVpIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODI5OTAzNzcsImV4cCI6MjA5ODU2NjM3N30.yDr6VzSgaMplA1fBrsnjx5bG5434mI2DXh9hcHfyDFs
# Required in production, not just optional: Phase 7's account deletion
# (app/services/account_service.py -> auth.admin.delete_user) only works
# with the service-role key, and this backend's own analyses/reports
# queries use it to bypass RLS (every query is scoped to the
# authenticated user's id in Python instead — see app/db/crud.py's
# module docstring). Keep this out of version control and never send it
# to the frontend.


# ML detectors: real models on in production for full detection quality.
# The Docker image installs torch/transformers/sentence-transformers/
# detoxify regardless of this flag (see backend/requirements.txt and
# backend/Dockerfile's size note) — expect the first request after a
# cold start/deploy to be slower while models load into memory.
ENABLE_ML_DETECTORS=True
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
INJECTION_SIMILARITY_THRESHOLD=0.6
TOXICITY_MODEL_NAME=original
TOXICITY_CATEGORY_THRESHOLD=0.5

RISK_THRESHOLD_SAFE=90
RISK_THRESHOLD_LOW=75
RISK_THRESHOLD_MEDIUM=50
RISK_THRESHOLD_HIGH=25

SCORE_INJECTION_PENALTY_WEIGHT=0.6
SCORE_INJECTION_CONFIDENCE_WEIGHT=0.4
SCORE_TOXICITY_PENALTY_WEIGHT=0.6
SCORE_TOXICITY_SEVERITY_WEIGHT=0.4
SCORE_HIGH_CONFIDENCE_FLOOR_THRESHOLD=0.9
SCORE_HIGH_CONFIDENCE_SCORE_CAP=15.0

# Relative to /app inside the container (WORKDIR in backend/Dockerfile).
# Mount a volume at /app/reports (see docker-compose.yml) so generated
# PDFs survive a container recreate/redeploy.
REPORTS_DIR=reports
