# Base URL for the SafePrompt AI backend API.
# In development, the Vite proxy forwards /api to http://localhost:8000,
# so this can usually stay as /api. Override for production deployments.
VITE_API_BASE_URL=/api

# Supabase project settings (Project Settings -> API in the Supabase dashboard).
# Use the anon/public key here — never the service role key, which must
# stay server-side only (see backend/.env.example).
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
