# Production environment template for the frontend BUILD (not a running
# server — see frontend/Dockerfile). These are Vite build-time
# variables: they get baked into the compiled JS wherever `npm run
# build` / `docker build` actually runs (CI, your hosting platform's
# build step, or a local `docker build --build-arg`), not read at
# container-start time. Setting them on an already-running container
# has no effect.

# The frontend's Nginx container proxies /api/* to the backend (see
# nginx.conf), so this can normally stay relative even in production.
# Only change it if the frontend and backend are deployed to genuinely
# different origins (e.g. separate hosting providers) instead of behind
# this same Nginx.
VITE_API_BASE_URL=/api

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
